# =================================================================
# CONFIGURATION ENVIRONMENT FOR SCRAPER PROJECT
# Copy this file to '.env' and fill in your actual credentials.
# =================================================================

# --- CDP Browser Provider ---
# Options: brightdata, oxylabs, or generic
CDP_PROVIDER=brightdata

# --- Bright Data Credentials ---
BRD_HOST=brd.superproxy.io
BRD_PORT=9222
BRD_USER_BASE=brd-customer-hl_a1fcaa97-zone-mcp_browser
BRD_PASS=on0tw2vl4ru5

# --- Oxylabs Credentials (Optional) ---
OXY_USER=your_oxylabs_customer_id
OXY_PASS=your_oxylabs_api_key

# --- Generic CDP WebSocket URL (Optional) ---
# If using other services not explicitly supported, put the full ws URL here
CDP_WS_URL=

# --- Captcha Solving Services (Optional) ---
# Options: auto (handled by CDP browser), 2captcha, capsolver
BYPASS_METHOD=auto
CAPTCHA_API_KEY=your_captcha_solving_api_key_here
